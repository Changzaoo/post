# ============================================================
# PostFlow - Environment Variables
# ============================================================
# 1. Copie este arquivo para .env (local) ou .env.local
# 2. Preencha com seus valores reais
# 3. NUNCA commite .env no Git
#
# VITE_ = variável PÚBLICA (exposta no browser) — apenas dados não-secretos
# Sem VITE_ = variável PRIVADA (backend/serverless apenas)
# ============================================================

# --- Firebase (público - vai para o bundle do browser) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- App ---
VITE_APP_NAME=PostFlow

# --- Telegram Bot (BACKEND ONLY - sem VITE_) ---
# Token do bot: obtenha no @BotFather
# Chat ID: obtenha no @getidsbot após adicionar o bot ao canal/grupo
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord (BACKEND ONLY - sem VITE_) ---
# Crie um Webhook em: Servidor Discord → Editar Canal → Integrações → Webhooks
DISCORD_WEBHOOK_URL=

# --- TikTok API (BACKEND ONLY - modo simulado, para OAuth futuro) ---
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback/tiktok

# --- Instagram / Meta API (BACKEND ONLY - modo simulado) ---
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback/instagram

# --- X (Twitter) API (BACKEND ONLY - modo simulado) ---
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback/x

# --- URL da aplicação ---
APP_URL=https://your-domain.vercel.app
